      "shiwilu_column": "SHIWILU",
      "pair_id_column": "pair_id",
      "enabled": true
    },
    {
      "name": "pdf_textos",
      "description": "Textos bilingües extraídos de II_TEXTOS_SHIWILU.pdf",
      "path": "data/intermediate/00_pdf/dataset_extraido_pdf.csv",
      "esp_column": "ESP",
      "shiwilu_column": "SHIWILU",
      "pair_id_column": "pair_id",
      "filter": {
        "column": "quality_flag",
        "keep": ["ok", "fallback_last_line_as_spanish"]
